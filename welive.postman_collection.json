{
  "info": {
    "name": "WeLive - Apartments API",
    "_postman_id": "welive-team4-apartments",
    "description": "WeLive 아파트 API 테스트 컬렉션",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "accessToken",
      "value": "",
      "type": "string"
    },
    {
      "key": "apartmentId",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "0. 사전 준비",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/health",
            "description": "서버 상태 확인"
          }
        },
        {
          "name": "로그인 (토큰 자동 저장)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const res = pm.response.json();",
                  "if (res.data && res.data.accessToken) {",
                  "  pm.collectionVariables.set('accessToken', res.data.accessToken);",
                  "  console.log('accessToken 저장 완료');",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"testuser1\",\n  \"password\": \"password123!\"\n}"
            },
            "description": "관리자용 API 테스트를 위해 로그인 후 accessToken을 자동 저장합니다."
          }
        }
      ]
    },
    {
      "name": "1. 아파트 목록 조회 (공개)",
      "item": [
        {
          "name": "전체 목록",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/apartments/public",
              "host": ["{{baseUrl}}"],
              "path": ["api", "apartments", "public"]
            },
            "description": "인증 불필요. APPROVED 상태 아파트만 반환."
          }
        },
        {
          "name": "keyword 검색",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/apartments/public?keyword=강남",
              "host": ["{{baseUrl}}"],
              "path": ["api", "apartments", "public"],
              "query": [
                { "key": "keyword", "value": "강남" }
              ]
            }
          }
        },
        {
          "name": "name 필터",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/apartments/public?name=테스트",
              "host": ["{{baseUrl}}"],
              "path": ["api", "apartments", "public"],
              "query": [
                { "key": "name", "value": "테스트" }
              ]
            }
          }
        },
        {
          "name": "address 필터",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/apartments/public?address=서울",
              "host": ["{{baseUrl}}"],
              "path": ["api", "apartments", "public"],
              "query": [
                { "key": "address", "value": "서울" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "2. 아파트 상세 조회 (공개)",
      "item": [
        {
          "name": "상세 조회 - 정상",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/apartments/public/{{apartmentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "apartments", "public", "{{apartmentId}}"]
            },
            "description": "목록 조회에서 얻은 id를 컬렉션 변수 apartmentId에 입력 후 사용."
          }
        },
        {
          "name": "상세 조회 - 존재하지 않는 ID (404 확인)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/apartments/public/nonexistent-id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "apartments", "public", "nonexistent-id"]
            },
            "description": "404 에러 응답을 확인합니다."
          }
        }
      ]
    },
    {
      "name": "3. 아파트 목록 조회 (관리자)",
      "item": [
        {
          "name": "전체 목록 (기본 페이징)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/apartments?page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "apartments"],
              "query": [
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "인증 필요. 모든 상태의 아파트를 페이징 조회."
          }
        },
        {
          "name": "PENDING 상태 필터",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/apartments?apartmentStatus=PENDING&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "apartments"],
              "query": [
                { "key": "apartmentStatus", "value": "PENDING" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "APPROVED 상태 필터",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/apartments?apartmentStatus=APPROVED&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "apartments"],
              "query": [
                { "key": "apartmentStatus", "value": "APPROVED" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            }
          }
        },
        {
          "name": "searchKeyword 검색",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/apartments?searchKeyword=강남&page=1&limit=10",
              "host": ["{{baseUrl}}"],
              "path": ["api", "apartments"],
              "query": [
                { "key": "searchKeyword", "value": "강남" },
                { "key": "page", "value": "1" },
                { "key": "limit", "value": "10" }
              ]
            },
            "description": "이름/주소/관리자 이름/이메일 통합 검색."
          }
        },
        {
          "name": "인증 없이 요청 (401 확인)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/apartments",
              "host": ["{{baseUrl}}"],
              "path": ["api", "apartments"]
            },
            "description": "Authorization 헤더 없이 요청. 401 에러 확인."
          }
        }
      ]
    },
    {
      "name": "4. 아파트 상세 조회 (관리자)",
      "item": [
        {
          "name": "상세 조회 - 정상",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/apartments/{{apartmentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "apartments", "{{apartmentId}}"]
            },
            "description": "인증 필요. dongRange, hoRange, 관리자 정보 포함 반환."
          }
        },
        {
          "name": "상세 조회 - 존재하지 않는 ID (404 확인)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/apartments/nonexistent-id",
              "host": ["{{baseUrl}}"],
              "path": ["api", "apartments", "nonexistent-id"]
            },
            "description": "404 에러 응답을 확인합니다."
          }
        },
        {
          "name": "상세 조회 - 인증 없이 요청 (401 확인)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/apartments/{{apartmentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["api", "apartments", "{{apartmentId}}"]
            },
            "description": "Authorization 헤더 없이 요청. 401 에러 확인."
          }
        }
      ]
    }
  ]
}
